# Friend skill trust profile — example only.
#
# Copy to ~/.shared/friend/trust-profile.env and source manually when needed:
#   source ~/.shared/friend/trust-profile.env        # bash / zsh
#   . ~/.shared/friend/trust-profile.env             # POSIX sh
#   # PowerShell: use $env:VAR = "value" directly
#
# This file is NOT auto-sourced by any script or hook.
# It does NOT modify global shell settings, PATH, or proxy config.
# All settings can also be passed as CLI args to friend_mailbox_bridge.py.

# ---------------------------------------------------------------------------
# FRIEND_TRUST_LEVEL — permission scope for cross-agent calls (both directions)
# ---------------------------------------------------------------------------
# safe      → Claude→Codex: --sandbox read-only
#             Codex→Claude (claude -p): --allowedTools Read,Grep,Glob,LS
#
# workspace → Claude→Codex: --sandbox workspace-write  (default; codex default)
#             Codex→Claude (claude -p): --permission-mode acceptEdits
#                                       --allowedTools Read,Grep,Glob,LS,Edit,MultiEdit,Write
#
# danger    → Claude→Codex: --dangerously-bypass-approvals-and-sandbox  (alias: --yolo)
#             Codex→Claude (claude -p): --dangerously-skip-permissions
#             REQUIRES: FRIEND_TRUST_DANGER_ACK=I_UNDERSTAND (see below)
#             Without the ACK, bridge silently degrades to workspace + logs to stderr/state.
#
# export FRIEND_TRUST_LEVEL=workspace

# ---------------------------------------------------------------------------
# FRIEND_TRUST_DANGER_ACK — required dead-man's switch for danger level
# ---------------------------------------------------------------------------
# Must be set to exactly "I_UNDERSTAND" when using FRIEND_TRUST_LEVEL=danger.
# Without this, danger degrades to workspace automatically.
#
# export FRIEND_TRUST_DANGER_ACK=I_UNDERSTAND

# ---------------------------------------------------------------------------
# FRIEND_DISPATCH_MODE — automation aggressiveness for claude -p dispatch in bridge
# ---------------------------------------------------------------------------
# Applies only to bridge --transport claude_cli (Codex→Claude auto-dispatch direction).
# Independent of FRIEND_TRUST_LEVEL (orthogonal axes).
#
# manual → no auto dispatch; bridge acts as protocol guard + archive only
# auto   → dispatch with failure_cache + TTL  (default)
# eager  → non-auth failure TTL × 0.5 (floor 30s); auth failures keep long TTL;
#          --force is the only explicit bypass
#
# Legacy FRIEND_TRUST_LEVEL=0/1/2 is mapped to FRIEND_DISPATCH_MODE with a
# deprecation warning: 0→manual, 1→auto, 2→eager. Migrate to FRIEND_DISPATCH_MODE.
#
# export FRIEND_DISPATCH_MODE=auto

# ---------------------------------------------------------------------------
# FRIEND_CODEX_EXEC_EXTRA_FLAGS — user escape hatch for codex exec (Claude→Codex)
# ---------------------------------------------------------------------------
# Extra flags appended to codex exec base command by Claude when constructing calls.
# Must be shlex-parseable. Do NOT shell-eval this value.
# Conflicts with sandbox/danger flags are logged to stderr;
# to allow override, set FRIEND_ALLOW_TRUST_OVERRIDE=1.
#
# Example: "--approval-policy=never-ask"
#
# export FRIEND_CODEX_EXEC_EXTRA_FLAGS=

# ---------------------------------------------------------------------------
# FRIEND_ALLOW_TRUST_OVERRIDE — permit FRIEND_CODEX_EXEC_EXTRA_FLAGS to conflict
# ---------------------------------------------------------------------------
# When set to 1, suppresses the conflict-detection warning and allows
# FRIEND_CODEX_EXEC_EXTRA_FLAGS to override sandbox/danger flags.
# Use with care; the override is still logged.
#
# export FRIEND_ALLOW_TRUST_OVERRIDE=0

# ---------------------------------------------------------------------------
# FRIEND_BRIDGE_FAILURE_TTL_SECONDS — override base TTL for all failure classes
# ---------------------------------------------------------------------------
# Overrides the per-classification base TTL in the bridge failure cache.
# Does not affect eager-mode scaling (scaling is applied after this base).
#
# export FRIEND_BRIDGE_FAILURE_TTL_SECONDS=600
